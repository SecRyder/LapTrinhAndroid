<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="BROADCAST RECEIVER DEMO"
            android:textColor="#1565C0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- ============================== -->
        <!--  SECTION 1: SYSTEM BROADCASTS  -->
        <!-- ============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="1. SYSTEM BROADCASTS (Dynamic Receiver)"
            android:textColor="#E65100"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Network Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trang thai mang (CONNECTIVITY_ACTION)"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvNetworkStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Battery Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trang thai pin (BATTERY_CHANGED)"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvBatteryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Airplane Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Che do may bay (AIRPLANE_MODE_CHANGED)"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAirplaneStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dang kiem tra..."
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ============================== -->
        <!--  SECTION 2: CUSTOM BROADCAST   -->
        <!-- ============================== -->


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="2. EVENT LOG"
            android:textColor="#E65100"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:minHeight="150dp"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Waiting for events..."
                android:textColor="#333333"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
