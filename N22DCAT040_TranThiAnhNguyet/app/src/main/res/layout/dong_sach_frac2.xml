<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imgHinh"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_alignParentStart="true"
        android:scaleType="centerCrop" />

    <CheckBox
        android:id="@+id/checkBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true" />

    <TextView
        android:id="@+id/txtTenSach"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/imgHinh"
        android:layout_marginStart="12dp"
        android:layout_toStartOf="@id/checkBox"
        android:layout_toEndOf="@id/imgHinh"
        android:text="Ten sach"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtTenTacGia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTenSach"
        android:layout_marginStart="12dp"
        android:layout_toStartOf="@id/checkBox"
        android:layout_toEndOf="@id/imgHinh"
        android:text="Ten tac gia"
        android:textColor="#888"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtGia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTenTacGia"
        android:layout_marginStart="12dp"
        android:layout_toStartOf="@id/checkBox"
        android:layout_toEndOf="@id/imgHinh"
        android:text="Gia"
        android:textColor="#E91E63"
        android:textSize="14sp"
        android:textStyle="bold" />

</RelativeLayout>