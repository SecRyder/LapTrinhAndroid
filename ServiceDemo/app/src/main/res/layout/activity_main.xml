<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="SERVICE DEMO - CHUONG 9"
            android:textColor="#1565C0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- =============================== -->
        <!-- FOREGROUND SERVICE - MUSIC -->
        <!-- =============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="FOREGROUND SERVICE - MUSIC"
            android:textColor="#E65100"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvSongName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chua phat nhac"
                android:textColor="#C62828"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMusicTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="00:00 / 00:00"
                android:textColor="#333333"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seekBarMusic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:text="PLAY"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnPause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#F57C00"
                    android:text="PAUSE"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnStopMusic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#C62828"
                    android:text="STOP"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- =============================== -->
        <!-- BACKGROUND SERVICE - DOWNLOAD -->
        <!-- =============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="BACKGROUND SERVICE - DOWNLOAD"
            android:textColor="#E65100"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvDownloadStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chua tai"
                android:textColor="#C62828"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressDownload"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:max="100"
                android:progress="0" />

            <Button
                android:id="@+id/btnDownload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#1565C0"
                android:text="TAI 5 ANH"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvDownloadDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#333333"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- =============================== -->
        <!-- BOUND SERVICE - CALCULATOR -->
        <!-- =============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="BOUND SERVICE - CALCULATOR"
            android:textColor="#E65100"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvBoundStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chua bind"
                android:textColor="#C62828"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtNum1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Nhap so thu 1"
                    android:inputType="numberDecimal" />

                <Spinner
                    android:id="@+id/spinnerOperator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

                <EditText
                    android:id="@+id/edtNum2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:hint="Nhap so thu 2"
                    android:inputType="numberDecimal" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBind"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:text="BIND"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnUnbind"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#C62828"
                    android:text="UNBIND"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#F57C00"
                android:text="CALCULATE"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvCalcResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="---"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvCalcHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#555555"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- =============================== -->
        <!-- EVENT LOG -->
        <!-- =============================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="LIFECYCLE LOG"
            android:textColor="#E65100"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_card"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Waiting for events..."
                android:textColor="#333333"
                android:textSize="11sp" />
        </ScrollView>

    </LinearLayout>
</ScrollView>
